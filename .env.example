# PAS Environment Variables Example
# Copy this file to .env and fill in your values

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# ! TODO: Add instructions on how to get the hf token
HF_TOKEN=your_hf_token_here

# AWS Credentials
# You can either provide the old authentication type for AWS or provide the new API keys for Bedrock
AWS_ACCESS_KEY_ID=aws_access_key_id
AWS_SECRET_ACCESS_KEY=secret_access_key_id
AWS_REGION_NAME="us-east-1"

# Bedrock API key
AWS_BEARER_TOKEN_BEDROCK=new_aws_api_key_here

# PAS Scenarios Directory Configuration
# Comma-separated list of directories to auto-register scenarios from
# Paths are relative to pas/scenarios/
# Default: benchmark
# Examples:
#   PAS_SCENARIOS_DIR=benchmark
#   PAS_SCENARIOS_DIR=generator
#   PAS_SCENARIOS_DIR=benchmark,generator
PAS_SCENARIOS_DIR=benchmark

# Environment Augmentation data path configuration
# Path is relative to the project root directory
ENV_AUGMENTATION_DATA_PATH="data/metaare_augmentation_data.json"
